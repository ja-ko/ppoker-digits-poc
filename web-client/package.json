{
  "name": "ppoker-web-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.18.0 <27",
    "npm": "12.0.x"
  },
  "packageManager": "npm@12.0.0",
  "scripts": {
    "prepare": "npm run prepare:ort",
    "prepare:ort": "node scripts/copy-ort-assets.mjs",
    "predev": "npm run prepare:ort",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run prepare:ort",
    "build": "tsc --noEmit && vite build",
    "prepreview": "npm run prepare:ort",
    "preview": "vite preview --host 0.0.0.0",
    "pretest": "npm run prepare:ort",
    "test": "vitest run",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "onnxruntime-web": "1.27.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
