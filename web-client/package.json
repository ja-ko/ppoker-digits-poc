{
  "name": "ppoker-web-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.18.0 <27",
    "npm": "12.0.x"
  },
  "packageManager": "npm@12.0.0",
  "scripts": {
    "prepare": "npm run prepare:ort",
    "prepare:ort": "node scripts/copy-ort-assets.mjs",
    "prepoc": "npm run build",
    "poc": "vite preview --host 0.0.0.0",
    "predev": "npm run prepare:ort",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "npm run prepare:ort",
    "build": "tsc --noEmit && vite build",
    "prepreview": "npm run prepare:ort",
    "preview": "vite preview --host 0.0.0.0",
    "pretest": "npm run prepare:ort",
    "test": "vitest run src scripts",
    "pretest:server": "npm run prepare:ort",
    "test:server": "node scripts/server-smoke.mjs",
    "test:launcher": "node scripts/launcher-smoke.mjs",
    "pretest:benchmark-cleanup": "npm run build",
    "test:benchmark-cleanup": "node scripts/browser-benchmark-failure-self-test.mjs",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:e2e:focused": "npm run test:e2e -- --grep",
    "test:e2e:debug": "npm run test:e2e -- --debug",
    "test:e2e:update": "npm run test:e2e -- --update-snapshots=all",
    "prebenchmark:browser": "npm run build",
    "benchmark:browser": "node scripts/browser-benchmark.mjs",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run lint && npm test && npm run build && npm run test:server && npm run test:launcher && npm run test:benchmark-cleanup",
    "verify:full": "npm run verify && npm run test:e2e"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "onnxruntime-web": "1.27.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
